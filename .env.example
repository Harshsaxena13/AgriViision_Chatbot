APP_NAME="AI Agricultural Assistant"
APP_VERSION="1.0.0"
API_PREFIX="/api/v1"
DEBUG=true
LOG_LEVEL="INFO"

# AI_PROVIDER can be rule_based, ollama, gemini, or openrouter.
AI_PROVIDER="rule_based"

# Gemini
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# OpenRouter
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-4o-mini"

AI_TIMEOUT_SECONDS=30

# Storage
DATABASE_PATH="data/agro_assistant.db"

# Local wheat disease image classification FastAPI service.
# Run your model API at this URL, and run this assistant app on another port.
DISEASE_API_URL="http://127.0.0.1:8000"
DISEASE_API_PREDICT_PATH="/predict"
DISEASE_API_FILE_FIELD="file"
DISEASE_API_TIMEOUT_SECONDS=90
